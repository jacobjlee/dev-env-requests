# App
APP_NAME=Dev Environment Request System
APP_VERSION=1.0.0
DEBUG=false
ENV=local

# Database
# local: SQLite (default)
DATABASE_URL=sqlite+aiosqlite:///./dev_env.db
# dev/staging/prod: injected by Vault/CI, example:
# DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/devenvdb

# API
API_PREFIX=/api/v1
ALLOWED_ORIGINS=["http://localhost:3000"]
